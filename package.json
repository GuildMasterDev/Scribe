{
  "name": "scribe",
  "version": "2.0.0",
  "description": "A kiosk-style Electron app providing author resources for writing, publishing, and marketing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --publish=never",
    "test": "node --check main.js && node --check preload.js && node --check renderer.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GuildMasterDev/Scribe.git"
  },
  "keywords": [
    "electron",
    "authors",
    "writing",
    "publishing",
    "resources",
    "kiosk"
  ],
  "author": "GuildMaster Development",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/GuildMasterDev/Scribe/issues"
  },
  "homepage": "https://github.com/GuildMasterDev/Scribe#readme",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "dev.guildmaster.scribe",
    "productName": "Scribe",
    "copyright": "Copyright © 2026 GuildMaster Development",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "resources/**/*",
      "!web/**/*",
      "!dist/**/*",
      "!.github/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "resources/icon-512.png",
      "category": "Office",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    }
  }
}
